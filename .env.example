# Deploy targets — droplet IPs per environment.
# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed as documentation.
#
# Currently both targets point to the same droplet. When staging
# migrates to its own server (or pilot moves to Hetzner), only the
# affected variable changes here.

DEPLOY_HOST_STAGING=
DEPLOY_HOST_PILOT=

# SSH user (typically root on a fresh droplet)
DEPLOY_USER=root

# Optional: explicit SSH key path (defaults to system default if empty)
DEPLOY_SSH_KEY=
